<div class="max-w-5xl mx-auto mt-10">
  <h1 class="text-3xl font-bold text-white mb-6">File a New Complaint</h1>
  
  <%# Form Section %>
  <div class="bg-black/20 p-6 rounded-2xl border border-white/10 mb-10">
    <%= form_with model: @complaint, url: complaints_path, local: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :message, "What is your issue?", class: "text-white/60 text-sm mb-2 block" %>
        <%= f.text_area :message, rows: 4, placeholder: "Describe your issue here...", class: "w-full bg-black/40 border border-white/20 rounded-lg p-3 text-white focus:ring-2 focus:ring-pink-500 outline-none" %>
      </div>
      <div>
        <%= f.label :image, "Attach a photo (optional)", class: "text-white/60 text-sm" %>
        <%= f.file_field :image, class: "block w-full text-sm text-white file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-pink-600 file:text-white hover:file:bg-pink-700" %>
      </div>
      <%= f.submit "Submit Complaint", class: "bg-pink-600 hover:bg-pink-700 text-white px-6 py-2 rounded-lg font-bold transition cursor-pointer" %>
    <% end %>
  </div>

  <h2 class="text-2xl font-bold text-white mb-6">My Complaint History</h2>
  
  <%# History Section with Empty State %>
  <div class="space-y-4">
  <% if @complaints&.any? %>
    <% @complaints.each do |complaint| %>
      <div class="bg-black/20 p-6 rounded-2xl border border-white/10 hover:border-white/20 transition flex gap-6">
        
        <%# Thumbnail Section %>
        <div class="flex-shrink-0">
          <% if complaint.image.attached? %>
            <%= image_tag complaint.thumbnail, 
                alt: "Complaint photo", 
                class: "w-20 h-20 rounded-xl object-cover border border-white/20" %>
          <% else %>
            <div class="w-20 h-20 rounded-xl bg-white/5 flex items-center justify-center border border-dashed border-white/10">
              <span class="text-[9px] text-white/20 text-center px-1">No Image</span>
            </div>
          <% end %>
        </div>

        <%# Content Section %>
        <div class="flex-grow">
          <p class="text-white/80 italic mb-4">"<%= complaint.message %>"</p>
          
          <div class="border-t border-white/10 pt-4 flex justify-between items-center">
            <%= link_to complaint_path(complaint), class: "group flex items-center space-x-2 text-pink-400 hover:text-pink-300 transition" do %>
              <span class="font-bold text-sm">Open Conversation</span>
              <span class="bg-white/10 text-white text-[10px] px-2 py-0.5 rounded-full">
                <%= complaint.comments.count %> messages
              </span>
            <% end %>
            <span class="text-white/30 text-xs"><%= complaint.created_at.strftime("%b %d, %Y") %></span>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-10 border border-dashed border-white/20 rounded-2xl">
      <p class="text-white/40">You haven't filed any complaints yet.</p>
    </div>
  <% end %>
</div>
</div>