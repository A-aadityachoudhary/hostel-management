<div class="max-w-5xl mx-auto mt-10 p-4 md:p-6">
  <h1 class="text-3xl font-bold text-white mb-6">
    <%= can?(:manage, :all) ? "All Complaints" : "My Complaint History" %>
  </h1>

  <div class="space-y-4">
    <% if @complaints.any? %>
      <% @complaints.each do |complaint| %>
        <div class="bg-black/20 p-6 rounded-2xl border border-white/10 transition hover:border-white/20 flex flex-col md:flex-row gap-6">
          
          <%# Thumbnail Display %>
          <% if complaint.image.attached? %>
            <div class="flex-shrink-0">
              <%= image_tag complaint.thumbnail, class: "w-24 h-24 rounded-xl object-cover border border-white/20" %>
            </div>
            <% else %>
            <div class="w-20 h-20 rounded-xl bg-white/5 flex items-center justify-center border border-dashed border-white/10">
              <span class="text-[9px] text-white/20 text-center px-1">No Image</span>
            </div>
          <% end %>

          <div class="flex-grow">
            <%# Header: Name, Email, and Date %>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-4">
              <p class="text-pink-400 font-bold text-sm">
                From: <%= complaint.user&.name || "Unknown User" %> 
                <span class="text-white/50 font-normal ml-1">
                  (<%= complaint.user&.email || "No Email" %>)
                </span>
              </p>
              <p class="text-white/30 text-xs tabular-nums mt-1 sm:mt-0">
                <%= complaint.created_at.strftime("%b %d, %Y") %>
              </p>
            </div>

            <%# Complaint Message %>
            <p class="text-white/80 italic mb-6">"<%= complaint.message %>"</p>
            
            <%# Footer: Chat Link and Actions %>
            <div class="border-t border-white/10 pt-4 flex justify-between items-center">
              <%= link_to complaint_path(complaint), class: "group flex items-center space-x-2 text-pink-400 hover:text-pink-300 transition" do %>
                <span class="font-bold text-sm">Open Conversation</span>
                <span class="bg-white/10 text-white text-[10px] px-2 py-0.5 rounded-full">
                  <%= complaint.comments.count %> messages
                </span>
              <% end %>
              
              <% if can? :destroy, complaint %>
                <%= button_to "Delete", complaint_path(complaint), 
                    method: :delete, 
                    data: { turbo_confirm: "Are you sure?" }, 
                    class: "text-red-400 hover:text-red-200 text-xs font-bold transition" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-20 bg-black/10 rounded-2xl border border-dashed border-white/10">
        <p class="text-white/40">No complaints found.</p>
      </div>
    <% end %>
  </div>
</div>