<div class="max-w-5xl mx-auto mt-10">
  <h1 class="text-3xl font-bold text-white mb-6">
    <%= current_user.admin? ? "All Complaints" : "My Complaint History" %>
  </h1>

  <div class="space-y-4">
    <% @complaints.each do |complaint| %>
      <div class="bg-black/20 p-6 rounded-2xl border border-white/10">
        
        <%# Header with Name and Email in parentheses %>
        <div class="flex justify-between items-start mb-4">
          <p class="text-pink-400 font-bold text-sm">
            From: <%= complaint.user&.name || "Unknown User" %> 
            <span class="text-white/50 font-normal">(<%= complaint.user&.email || "No Email" %>)</span>
          </p>
          <p class="text-white/30 text-xs"><%= complaint.created_at.strftime("%b %d, %Y") %></p>
        </div>

        <p class="text-white/70 italic">"<%= complaint.message %>"</p>
        
        <%# Reply Section %>
        <div class="mt-4 pt-4 border-t border-white/10">
          <% if complaint.reply.present? %>
            <p class="text-pink-300 font-bold text-sm">Admin Reply:</p>
            <p class="text-white"><%= complaint.reply %></p>
          <% elsif current_user.admin? %>
            <%= form_with model: complaint, url: complaint_path(complaint), method: :patch do |f| %>
              <%= f.text_area :reply, placeholder: "Write a reply...", class: "w-full bg-black/40 border border-white/20 rounded-lg p-3 text-white text-sm" %>
              <%= f.submit "Send Reply", class: "mt-2 bg-pink-600 hover:bg-pink-700 text-white px-4 py-2 rounded-lg text-xs font-bold transition" %>
            <% end %>
          <% else %>
            <p class="text-white/40 text-sm italic">No reply yet.</p>
          <% end %>
        </div>

        <%# Admin Delete Button %>
        <% if current_user.admin? %>
          <%= button_to "Delete Complaint", complaint_path(complaint), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "mt-4 text-red-500 hover:text-red-300 text-xs font-bold underline" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>