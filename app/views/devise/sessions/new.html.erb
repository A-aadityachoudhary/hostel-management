<div class="min-h-[80vh] flex flex-col items-center justify-center p-6">
  <div class="bg-white/10 backdrop-blur-lg p-10 rounded-3xl shadow-2xl border border-white/20 w-full max-w-sm">
    <h2 class="text-3xl font-bold mb-8 text-center text-white">Welcome Back</h2>

    <%# Devise standard flash alert rendering %>
    <% if flash[:alert] %>
      <div class="bg-red-500/50 text-white p-3 rounded-lg mb-6 text-sm text-center backdrop-blur-sm">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%# Use resource: @user or scope name for Devise form_with %>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium mb-1 text-white/80" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full bg-white/10 border border-white/20 rounded-xl p-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-pink-500", required: true %>
      </div>

      <div class="mb-8">
        <%= f.label :password, class: "block text-sm font-medium mb-1 text-white/80" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full bg-white/10 border border-white/20 rounded-xl p-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-pink-500", required: true %>
      </div>

      <%= f.submit "Login", class: "w-full bg-pink-600 text-white py-3 rounded-full font-bold hover:bg-pink-700 transition duration-300 shadow-lg cursor-pointer" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-white/70">
      Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name), class: "text-white font-bold hover:underline" %>
    </p>
  </div>
</div>