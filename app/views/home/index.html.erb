<div class="min-h-screen bg-gray-50 flex flex-col items-center justify-center p-6">
  <h1 class="text-4xl font-bold text-gray-800 mb-6">Welcome to Hostel Management System</h1>
  
  <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md text-center">
    <% if logged_in? %>
      <p class="text-lg mb-4">Hello, <%= current_user.name %>!</p>
      <p class="mb-6">Role: <span class="capitalize font-semibold"><%= current_user.role %></span></p>
      
      <% if current_user.admin? %>
        <%= link_to "Go to Admin Dashboard", admin_index_path, class: "block bg-blue-600 text-white py-2 px-4 rounded mb-2 hover:bg-blue-700" %>
      <% end %>
      
      <%= button_to "Logout", logout_path, method: :delete, class: "w-full bg-red-500 text-white py-2 px-4 rounded hover:bg-red-600" %>
    <% else %>
      <p class="mb-6 text-gray-600">Please log in to manage your hostel allocations.</p>
      <%= link_to "Login", login_path, class: "block bg-blue-600 text-white py-2 px-4 rounded mb-2 hover:bg-blue-700" %>
      <%= link_to "Sign Up", signup_path, class: "block bg-gray-200 text-gray-800 py-2 px-4 rounded hover:bg-gray-300" %>
    <% end %>
  </div>
</div>