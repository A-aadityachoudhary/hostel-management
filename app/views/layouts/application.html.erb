<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hostel Management" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hostel Management">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="bg-gray-800 p-4 text-white">
      <div class="container mx-auto flex items-center justify-between">
        <%= link_to "HostelSystem", root_path, class: "font-bold text-xl hover:text-gray-300" %>
        
        <div class="flex items-center space-x-6">
          <% if logged_in? %>
            <%= link_to "Home", root_path, class: "hover:text-gray-300" %>
            
            <% if current_user.admin? %>
              <%= link_to "Admin Dashboard", admin_index_path, class: "hover:text-gray-300" %>
        <% end %>

        <% if current_user.student? %>
              <%= link_to "My Room", my_room_path, class: "hover:text-gray-300" %>
            <% end %>
    
            <%= button_to "Logout", logout_path, method: :delete, class: "text-red-400 hover:text-red-300" %>
          <% else %>
            <%= link_to "Login", login_path, class: "hover:text-gray-300" %>
            <%= link_to "Sign Up", signup_path, class: "bg-blue-600 px-4 py-2 rounded hover:bg-blue-700" %>
          <% end %>
        </div>
      </div>
    </nav>
    
    <main class="container mx-auto p-4">
      <% if flash[:notice] %><div class="bg-green-100 p-2 mb-4"><%= flash[:notice] %></div><% end %>
      <% if flash[:alert] %><div class="bg-red-100 p-2 mb-4"><%= flash[:alert] %></div><% end %>
      <%= yield %>
    </main>
  </body>
</html>
