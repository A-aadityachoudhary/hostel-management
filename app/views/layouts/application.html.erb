<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hostel Management" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans antialiased min-h-screen">
    
    <nav class="bg-transparent p-6 text-white">
      <div class="container mx-auto flex items-center justify-between">
        <%= link_to "HostelSystem", root_path, class: "font-bold text-2xl tracking-tight hover:opacity-80 transition" %>

        <div class="flex items-center space-x-8 text-lg font-medium">
          <% if logged_in? %>
            <%= link_to "Home", root_path, class: "hover:text-pink-200 transition" %>

            <% if current_user.admin? %>
              <%= link_to "Admin Dashboard", admin_index_path, class: "hover:text-pink-200 transition" %>
              <%= link_to "Manage Tasks", tasks_path, class: "hover:text-pink-200 transition" %>
              <%= link_to "View Complaints", complaints_path, class: "hover:text-pink-200 transition " %>
            <% elsif current_user.staff? %>
              <%= link_to "My Tasks", staff_dashboard_path, class: "hover:text-pink-200 transition" %>
              <%= link_to "File Complaint", new_complaint_path, class: "hover:text-pink-200 transition" %>
            <% end %>

            <% if current_user.student? %>
              <%= link_to "My Room", my_room_path, class: "hover:text-pink-200 transition" %>
              <%= link_to "File Complaint", new_complaint_path, class: "hover:text-pink-200 transition" %>
            <% end %>

            <%= button_to "Logout", logout_path, method: :delete, class: "bg-white/20 px-5 py-2 rounded-full hover:bg-white/30 transition" %>
          <% else %>
            <%= link_to "Login", login_path, class: "hover:text-pink-200 transition" %>
            <%= link_to "Sign Up", signup_path, class: "bg-pink-600 px-6 py-2 rounded-full hover:bg-pink-700 transition shadow-lg" %>
          <% end %>
        </div>
      </div>
    </nav>
    
    <%# Fixed container for floating flash messages %>
    <div class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4 pointer-events-none">
      <% if flash[:notice] %>
        <div class="flash-message pointer-events-auto bg-green-500/80 text-white p-4 rounded-xl shadow-lg mb-2 text-center">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-message pointer-events-auto bg-red-500/80 text-white p-4 rounded-xl shadow-lg mb-2 text-center">
          <%= flash[:alert] %>
        </div>
      <% end %>
    </div>
    
    <main class="container mx-auto p-6">
      <%= yield %>
    </main>

    <script>
      const fadeOutFlash = () => {
        const flashMessages = document.querySelectorAll('.flash-message');
        
        setTimeout(() => {
          flashMessages.forEach(msg => {
            msg.style.transition = "opacity 0.5s ease";
            msg.style.opacity = "0";
            setTimeout(() => msg.remove(), 500);
          });
        }, 1800);
      };

      document.addEventListener("turbo:load", fadeOutFlash);
    </script>
  </body>
</html>