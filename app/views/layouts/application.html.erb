<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hostel Management" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans antialiased min-h-screen bg-slate-900 text-white">
    
    <nav class="p-6">
      <div class="container mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <%= link_to "HostelSystem", root_path, class: "font-bold text-2xl tracking-tight hover:opacity-80 transition" %>
    
        <%# Changed to flex-wrap to allow items to move to a new line on small screens %>
        <div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-2 text-sm md:text-lg font-medium">
          <% if user_signed_in? %>
            <%= link_to "Home", root_path, class: "hover:text-pink-200 transition" %>
    
            <%# Admin Section %>
            <% if can? :manage, :all %>
              <%= link_to "Admin", admin_index_path, class: "hover:text-pink-200 transition" %>
              <%= link_to "Tasks", tasks_path, class: "hover:text-pink-200 transition" %>
              <%= link_to "Complaints", complaints_path, class: "hover:text-pink-200 transition" %>
            <% end %>
            
            <%# Staff Section %>
            <% if current_user.staff? && can?(:read, :staff_dashboard) %>
              <%= link_to "Staff", staff_dashboard_path, class: "hover:text-pink-200 transition" %>
            <% end %>
    
            <%# Complaint Section %>
            <% if can? :create, Complaint %>
              <%= link_to "Complaint", complaints_path, class: "hover:text-pink-200 transition" %>
            <% end %>
    
            <%# Student Section %>
            <% if current_user.student? %>
              <%= link_to "My Room", my_room_path, class: "hover:text-pink-200 transition" %>
            <% end %>
    
            <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "bg-white/10 px-4 py-1.5 rounded-full hover:bg-white/20 transition text-xs md:text-sm" %>
          
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "hover:text-pink-200 transition" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "bg-pink-600 px-5 py-2 rounded-full hover:bg-pink-700 transition shadow-lg text-sm" %>
          <% end %>
        </div>
      </div>
    </nav>
    
    <%# Flash Messages %>
    <div class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4 pointer-events-none">
      <% flash.each do |type, message| %>
        <div class="flash-message pointer-events-auto <%= type == 'notice' ? 'bg-green-500/80' : 'bg-red-500/80' %> text-white p-4 rounded-xl shadow-lg mb-2 text-center backdrop-blur-md">
          <%= message %>
        </div>
      <% end %>
    </div>
    
    <main class="container mx-auto p-6">
      <%= yield %>
    </main>

    <script>
      const fadeOutFlash = () => {
        const flashMessages = document.querySelectorAll('.flash-message');
        setTimeout(() => {
          flashMessages.forEach(msg => {
            msg.style.transition = "opacity 0.5s ease";
            msg.style.opacity = "0";
            setTimeout(() => msg.remove(), 500);
          });
        }, 1800);
      };
      document.addEventListener("turbo:load", fadeOutFlash);
    </script>
  </body>
</html>