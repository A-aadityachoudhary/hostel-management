<div class="min-h-[80vh] flex flex-col items-center justify-center p-6">
  <%# Glassmorphic Card %>
  <div class="bg-white/10 backdrop-blur-xl p-10 rounded-3xl shadow-2xl border border-white/20 w-full max-w-sm">
    <h2 class="text-3xl font-bold mb-8 text-center text-white">Create Account</h2>

    <%= form_with model: @user, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.text_field :name, placeholder: "Full Name", class: "w-full bg-white/10 border border-white/20 rounded-xl p-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-pink-500" %>
        </div>
        
        <div>
          <%= f.email_field :email, placeholder: "Email", class: "w-full bg-white/10 border border-white/20 rounded-xl p-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-pink-500" %>
        </div>

        <div>
          <%= f.password_field :password, placeholder: "Password", class: "w-full bg-white/10 border border-white/20 rounded-xl p-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-pink-500" %>
        </div>

        <div>
          <%= f.label :role, class: "block text-sm font-medium mb-1 text-white/80" %>
          <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, { class: "w-full bg-white/10 border border-white/20 rounded-xl p-3 text-white focus:outline-none focus:ring-2 focus:ring-pink-500" } %>
        </div>

        <%= f.submit "Sign Up", class: "w-full bg-pink-600 text-white py-3 mt-4 rounded-full font-bold hover:bg-pink-700 transition duration-300 shadow-lg cursor-pointer" %>
      </div>
    <% end %>

    <p class="mt-6 text-center text-sm text-white/70">
      Already have an account? <%= link_to "Login", login_path, class: "text-white font-bold hover:underline" %>
    </p>
  </div>
</div>