<div class="max-w-2xl mx-auto p-6">
  <h1 class="text-4xl font-bold mb-8 text-white">My Room Allocation</h1>

  <%# Authorization Check: Only show data if the user is authorized to read this specific allocation %>
  <% if @allocation && can?(:read, @allocation) %>
    <div class="bg-white/10 backdrop-blur-xl p-8 rounded-3xl shadow-2xl border border-white/20">
      <div class="space-y-4">
        <div class="flex items-center justify-between border-b border-white/10 pb-4">
          <p class="text-xl font-medium text-white/80">Room Number</p>
          <p class="text-2xl font-bold text-white"><%= @allocation.room.room_number %></p>
        </div>
        
        <div class="flex items-center justify-between border-b border-white/10 pb-4">
          <p class="text-xl font-medium text-white/80">Block</p>
          <p class="text-xl font-bold text-white"><%= @allocation.room.block.name %></p>
        </div>

        <div class="flex items-center justify-between">
          <p class="text-xl font-medium text-white/80">Status</p>
          <span class="px-4 py-1 bg-green-500/30 text-green-100 rounded-full font-bold border border-green-500/50">
            <%= @allocation.status.humanize %>
          </span>
        </div>
      </div>
      
      <p class="text-white/50 mt-8 text-sm italic">
        Allocated on: <%= @allocation.created_at.strftime("%B %d, %Y") %>
      </p>
    </div>
  <% else %>
    <div class="bg-white/5 backdrop-blur-md p-8 rounded-3xl border border-white/10 text-center">
      <p class="text-lg text-white/80">You do not have any active room allocations at the moment.</p>
    </div>
  <% end %>
</div>