<h2 class="text-2xl font-bold">My Room Allocation</h2>

<% if @allocation %>
  <div class="mt-6 p-6 border border-gray-200 rounded shadow-sm">
    <p class="text-lg"><strong>Room Number:</strong> <%= @allocation.room.room_number %></p>
    <p class="text-lg"><strong>Block:</strong> <%= @allocation.room.block.name %></p>
    <p class="text-lg"><strong>Status:</strong> <span class="text-green-600 font-semibold">Active</span></p>
    <p class="text-gray-600 mt-2">Allocated on: <%= @allocation.created_at.strftime("%B %d, %Y") %></p>
  </div>
<% else %>
  <div class="mt-6 p-6 bg-yellow-50 border border-yellow-200 rounded text-yellow-800">
    <p>You do not have any active room allocations.</p>
  </div>
<% end %>