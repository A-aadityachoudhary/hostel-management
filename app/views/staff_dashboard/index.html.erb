<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-4xl font-bold mb-8 text-white">My Assigned Tasks</h1>

  <% if @my_tasks.any? %>
    <div class="grid gap-4">
      <% @my_tasks.each do |task| %>
        <%# Ghost Card - using dark transparency and thin borders %>
        <div class="bg-black/20 backdrop-blur-md border border-white/10 p-6 rounded-2xl shadow-xl flex items-center justify-between hover:bg-black/30 transition">
          <div>
            <h3 class="text-xl font-bold text-white"><%= task.title %></h3>
            <p class="text-white/60 text-sm mt-1">Assigned on: <%= task.created_at.strftime("%B %d, %Y") %></p>
          </div>
          
          <%# Status Badge - using border-only style %>
          <div class="px-4 py-2 bg-black/20 rounded-full border border-pink-500/30">
            <span class="text-sm font-bold text-pink-200 uppercase tracking-wider">
              <%= task.status&.humanize || "Pending" %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-black/20 backdrop-blur-md p-10 rounded-3xl border border-white/10 text-center">
      <p class="text-xl text-white/70">No tasks currently assigned to you.</p>
    </div>
  <% end %>
</div>